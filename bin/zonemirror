#!/usr/bin/env bash
# zonemirror — operator CLI for the ZoneMirror cPanel plugin.
#
# Subcommands:
#   zonemirror version            Show installed and latest available version.
#   zonemirror check              Compare installed vs latest; exit 0 if up to date, 10 if updates exist.
#   zonemirror update [--dry-run] Upgrade in place to the latest GitHub release.
#   zonemirror status             Daemon, hook, and queue health snapshot.
#   zonemirror auto-update on|off Enable/disable the systemd auto-update timer.
#   zonemirror logs [-n N]        Tail the plugin log (default: 50 lines).
#   zonemirror help               Show this help.
#
# All update operations require root.

set -euo pipefail

PLUGIN_ID="zonemirror"
PREFIX="/usr/local/cpanel/3rdparty/${PLUGIN_ID}"
SYSTEM_DIR="/var/cpanel/${PLUGIN_ID}"
LOG_FILE="${SYSTEM_DIR}/logs/zonemirror.log"
SERVICE_NAME="${PLUGIN_ID}d"
TIMER_NAME="${PLUGIN_ID}d-updater.timer"
GH_OWNER="${GH_OWNER:-zonemirror}"
GH_REPO="${GH_REPO:-zonemirror}"
BOOTSTRAP_URL="https://raw.githubusercontent.com/${GH_OWNER}/${GH_REPO}/main/packaging/bootstrap.sh"

die() { echo "zonemirror: $*" >&2; exit 1; }

require_root() {
  [[ $EUID -eq 0 ]] || die "this subcommand requires root (sudo)."
}

installed_version() {
  if [[ -f "$PREFIX/VERSION" ]]; then
    tr -d '[:space:]' < "$PREFIX/VERSION"
  else
    echo "unknown"
  fi
}

latest_version() {
  curl -fsSL "https://api.github.com/repos/${GH_OWNER}/${GH_REPO}/releases/latest" \
    | grep -oE '"tag_name"[[:space:]]*:[[:space:]]*"[^"]+' \
    | sed -E 's/.*"([^"]+)$/\1/' \
    | head -n1
}

normalize_ver() {
  # Strip leading "v" for comparison.
  echo "${1#v}"
}

cmd_version() {
  local inst latest
  inst="$(installed_version)"
  latest="$(latest_version 2>/dev/null || true)"
  echo "installed: ${inst}"
  echo "latest:    ${latest:-unknown}"
}

cmd_check() {
  local inst latest
  inst="$(normalize_ver "$(installed_version)")"
  latest="$(latest_version 2>/dev/null || true)"
  if [[ -z "$latest" ]]; then
    echo "could not fetch latest from GitHub" >&2
    exit 2
  fi
  latest="$(normalize_ver "$latest")"
  if [[ "$inst" == "$latest" ]]; then
    echo "up-to-date (${inst})"
    exit 0
  fi
  if [[ "$(printf '%s\n%s\n' "$inst" "$latest" | sort -V | tail -n1)" == "$latest" ]]; then
    echo "update available: ${inst} -> ${latest}"
    exit 10
  fi
  echo "installed (${inst}) is newer than latest released (${latest})"
  exit 0
}

cmd_update() {
  require_root
  local dry_run="false"
  for arg in "${@:-}"; do
    case "$arg" in
      --dry-run|-n) dry_run="true" ;;
    esac
  done

  local inst latest
  inst="$(normalize_ver "$(installed_version)")"
  latest="$(latest_version)"
  [[ -n "$latest" ]] || die "could not fetch latest version."
  latest_norm="$(normalize_ver "$latest")"

  if [[ "$inst" == "$latest_norm" ]]; then
    echo "already on $inst, nothing to do."
    return 0
  fi
  if [[ "$(printf '%s\n%s\n' "$inst" "$latest_norm" | sort -V | tail -n1)" != "$latest_norm" ]]; then
    echo "installed ($inst) is newer than latest released ($latest_norm); refusing."
    return 0
  fi

  echo "would upgrade: $inst -> $latest_norm"
  if [[ "$dry_run" == "true" ]]; then
    return 0
  fi

  # Delegate to bootstrap.sh from current main; pinning the version.
  VERSION="$latest" bash <(curl -fsSL "$BOOTSTRAP_URL")
}

cmd_status() {
  local q d
  echo "== plugin =="
  echo "  installed: $(installed_version)"
  echo "  prefix:    $PREFIX"
  echo
  echo "== daemon =="
  systemctl --no-pager --quiet is-active "$SERVICE_NAME" \
    && echo "  $SERVICE_NAME: active" \
    || echo "  $SERVICE_NAME: NOT active"
  echo
  echo "== auto-update timer =="
  if systemctl --quiet is-enabled "$TIMER_NAME" 2>/dev/null; then
    systemctl --no-pager status "$TIMER_NAME" | head -n 5
  else
    echo "  disabled (enable with: sudo zonemirror auto-update on)"
  fi
  echo
  echo "== hooks =="
  /usr/local/cpanel/bin/manage_hooks list 2>/dev/null \
    | awk -v plugin="$PLUGIN_ID" '$0 ~ plugin {found++} END {print "  registered:", (found+0)}'
  echo
  echo "== queues =="
  for d in /home/*/.zonemirror/queue.sqlite /root/.zonemirror/queue.sqlite; do
    [[ -f "$d" ]] || continue
    q="$(sqlite3 "$d" 'SELECT COUNT(*) FROM events WHERE dead_at IS NULL;' 2>/dev/null || echo '?')"
    dl="$(sqlite3 "$d" 'SELECT COUNT(*) FROM events WHERE dead_at IS NOT NULL;' 2>/dev/null || echo '?')"
    echo "  $d  pending=$q  dead=$dl"
  done
}

cmd_auto_update() {
  require_root
  case "${1:-}" in
    on|enable)
      systemctl daemon-reload
      systemctl enable --now "$TIMER_NAME"
      systemctl --no-pager status "$TIMER_NAME" | head -n 5
      ;;
    off|disable)
      systemctl disable --now "$TIMER_NAME" || true
      echo "auto-update disabled."
      ;;
    *)
      die "usage: zonemirror auto-update on|off"
      ;;
  esac
}

cmd_logs() {
  local n=50
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n) shift; n="${1:-50}" ;;
      *) ;;
    esac
    shift || true
  done
  [[ -f "$LOG_FILE" ]] || die "log file not found: $LOG_FILE"
  tail -n "$n" "$LOG_FILE"
}

cmd_help() {
  sed -n '2,15p' "$0" | sed 's/^# \{0,1\}//'
}

main() {
  local sub="${1:-help}"
  shift || true
  case "$sub" in
    version)      cmd_version "$@" ;;
    check)        cmd_check "$@" ;;
    update)       cmd_update "$@" ;;
    status)       cmd_status "$@" ;;
    auto-update)  cmd_auto_update "$@" ;;
    logs)         cmd_logs "$@" ;;
    help|-h|--help) cmd_help ;;
    *)            die "unknown subcommand: $sub (try: zonemirror help)" ;;
  esac
}

main "$@"
