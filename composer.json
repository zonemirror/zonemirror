{
  "name": "zonemirror/zonemirror",
  "description": "cPanel plugin that syncs DNS changes from cPanel Zone Editor to Cloudflare in real time.",
  "type": "project",
  "license": "MIT",
  "keywords": [
    "cpanel",
    "whm",
    "cloudflare",
    "dns",
    "sync",
    "plugin",
    "hooks"
  ],
  "authors": [
    {
      "name": "ZoneMirror",
      "homepage": "https://github.com/zonemirror"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-pdo_sqlite": "*",
    "ext-openssl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "friendsofphp/php-cs-fixer": "^3.64",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-strict-rules": "^2.0"
  },
  "suggest": {
    "ext-sodium": "Preferred AEAD cipher (XChaCha20-Poly1305) for token-at-rest encryption."
  },
  "autoload": {
    "psr-4": {
      "ZoneMirror\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ZoneMirror\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --colors=always",
    "test:coverage": "phpunit --colors=always --coverage-text --coverage-clover=coverage.xml",
    "analyse": "phpstan analyse --memory-limit=512M",
    "format:php": "php-cs-fixer fix --config=.php-cs-fixer.php --allow-risky=yes",
    "lint:php": "php-cs-fixer fix --config=.php-cs-fixer.php --allow-risky=yes --dry-run --using-cache=no --diff",
    "check": [
      "@lint:php",
      "@analyse",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "preferred-install": "dist"
  },
  "minimum-stability": "stable"
}
