{
  "name": "host/cpanel-cloudflare-sync",
  "description": "cPanel plugin to sync DNS changes to Cloudflare.",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=7.4",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-pdo_sqlite": "*"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.64"
  },
  "autoload": {
    "psr-4": {
      "CfSync\\": "plugin/"
    }
  },
  "scripts": {
    "format:php": "php-cs-fixer fix --config=.php-cs-fixer.php --allow-risky=yes",
    "lint:php": "php-cs-fixer fix --config=.php-cs-fixer.php --allow-risky=yes --dry-run --using-cache=no --diff"
  }
}
